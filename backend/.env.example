# === PostgreSQL (misma DB que la app principal, nuevas tablas) ===
DATABASE_URL=postgresql://postgres.jutczosptsbmjqhzprvp:Powing2025!@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# === JWT ===
JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio

# === Bridge Key (la misma de la app principal, para que n8n autentique) ===
BRIDGE_KEY=bridge-local-dev-key-2026

# === n8n Webhooks ===
# n8n llama a ESTE endpoint cuando termina de ejecutar un workflow
# (ej. http://localhost:8080/api/notify)
# Y este backend llama a N8N cuando el usuario aprueba/cancela un caso:
N8N_PENDING_ACTION_WEBHOOK_URL=https://n8n.srv1515461.hstgr.cloud/webhook/pending-action

# === Usuarios de la app (formato: email:bcrypt_hash, separados por ;) ===
# Para generar un hash: el endpoint POST /api/auth/setup lo hace automáticamente
# O podés correr: go run cmd/hash/main.go
APP_USERS=admin:hash_aqui

# === Push Notifications (VAPID keys para Web Push) ===
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# === Server ===
PORT=8080

# === Expiración de casos (días) ===
CASE_EXPIRY_DAYS=1
